# DeFi Agent Toolkit - Environment Variables
# Copy to .env and fill in your values
# NEVER commit .env to version control!

# RPC ENDPOINTS (required)
# Get free endpoints from Alchemy, Infura, or QuickNode
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
ARB_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
OP_RPC_URL=https://opt-mainnet.g.alchemy.com/v2/YOUR_KEY

# DEX AGGREGATOR API KEYS (optional)
ONEINCH_API_KEY=your_key_here
ZERORX_API_KEY=your_key_here
PARASWAP_API_KEY=your_key_here

# PORTFOLIO APIs (optional)
COINGECKO_API_KEY=your_key_here
ZAPPER_API_KEY=your_key_here
DEBANK_API_KEY=your_key_here

# SECURITY SETTINGS
REQUIRE_SIMULATION=true
MAX_SLIPPAGE=5.0
